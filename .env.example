# Sanity (public - used by frontend)
VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production

# Sanity (secret - used by API routes only, never exposed to browser)
SANITY_WRITE_TOKEN=your_write_token

# Resend (secret - used by API routes only for email notifications)
RESEND_API_KEY=your_resend_api_key
